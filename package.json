{
	"name": "news-snapshotter",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc -b && vite build",
		"check": "tsc -b && vite build && wrangler deploy --dry-run",
		"deploy": "pnpm run build && pnpm run db:migrate:remote && wrangler deploy",
		"db:migrate:local": "wrangler d1 migrations apply HISTORY_DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply HISTORY_DB --remote",
		"dev": "vite",
		"start": "vite",
		"test": "node --test",
		"cf-typegen": "wrangler types",
		"format": "vp fmt"
	},
	"dependencies": {
		"@cloudflare/puppeteer": "^1.1.0",
		"react": "19.2.7",
		"react-dom": "19.2.7"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.45.0",
		"@cloudflare/workers-types": "^5.20260716.1",
		"@types/node": "^26.1.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"typescript": "^7.0.2",
		"vite": "8.1.5",
		"vite-plus": "^0.2.4",
		"wrangler": "^4.111.0"
	}
}
