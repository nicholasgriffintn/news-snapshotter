{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"composite": true,
		"jsx": "react-jsx",
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleDetection": "force",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"noUncheckedSideEffectImports": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2024",
		"types": ["vite/client"]
	},
	"include": ["src/core/contracts.ts", "src/react-app"]
}
