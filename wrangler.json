{
	"name": "news-snapshotter",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-16",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"workers_dev": false,
	"preview_urls": false,
	"placement": {
		"mode": "smart"
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 0.1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 0.1,
			"invocation_logs": false
		}
	},
	"dev": {
		"port": 8787
	},
	"routes": [
		{
			"pattern": "news-snapshotter.pashi.app",
			"custom_domain": true
		}
	],
	"browser": {
		"binding": "BROWSER"
	},
	"workflows": [
		{
			"name": "news-snapshotter",
			"binding": "NEWS_SNAPSHOTTER",
			"class_name": "NewsSnapshotterWorkflow"
		}
	],
	"kv_namespaces": [
		{
			"binding": "CAPTURE_FAILURES"
		}
	],
	"ratelimits": [
		{
			"name": "CONTACT_RATE_LIMIT",
			"namespace_id": "78241",
			"simple": {
				"limit": 3,
				"period": 60
			}
		}
	],
	"send_email": [
		{
			"name": "CONTACT_EMAIL",
			"destination_address": "pashi@nicholasgriffin.dev",
			"allowed_sender_addresses": ["pashi@nicholasgriffin.dev"]
		}
	],
	"r2_buckets": [
		{
			"binding": "SCREENSHOTS",
			"bucket_name": "news-snapshotter",
			"preview_bucket_name": "news-snapshotter-preview"
		}
	],
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*"]
	}
}
