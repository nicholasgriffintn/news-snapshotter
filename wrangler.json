{
	"name": "news-snapshotter",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-16",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"workers_dev": false,
	"preview_urls": false,
	"placement": {
		"region": "aws:eu-west-1"
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 0.1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 0.1,
			"invocation_logs": false
		}
	},
	"dev": {
		"port": 8787
	},
	"triggers": {
		"crons": [
			"0 * * * *"
		]
	},
	"routes": [
		{
			"pattern": "news-snapshotter.pashi.app",
			"custom_domain": true
		}
	],
	"browser": {
		"binding": "BROWSER"
	},
	"workflows": [
		{
			"name": "news-snapshotter",
			"binding": "NEWS_SNAPSHOTTER",
			"class_name": "NewsSnapshotterWorkflow"
		}
	],
	"kv_namespaces": [
		{
			"binding": "CAPTURE_FAILURES",
			"id": "eb6fb2073a344839a1ec735891a00527"
		}
	],
	"ratelimits": [
		{
			"name": "CONTACT_RATE_LIMIT",
			"namespace_id": "78241",
			"simple": {
				"limit": 3,
				"period": 60
			}
		}
	],
	"send_email": [
		{
			"name": "CONTACT_EMAIL"
		}
	],
	"r2_buckets": [
		{
			"binding": "ARCHIVE_DATA",
			"bucket_name": "news-snapshotter-archive-data",
			"preview_bucket_name": "news-snapshotter-archive-data-preview"
		},
		{
			"binding": "SCREENSHOTS",
			"bucket_name": "news-snapshotter",
			"preview_bucket_name": "news-snapshotter-preview"
		}
	],
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
		"run_worker_first": [
			"/api/*"
		]
	},
	"d1_databases": [
		{
			"binding": "HISTORY_DB",
			"database_name": "news-snapshotter-history",
			"database_id": "903439ec-9e2f-432b-9c7a-fcd349d28620",
			"migrations_dir": "migrations",
			"remote": true
		}
	],
	"queues": {
		"producers": [
			{
				"queue": "news-snapshotter-history-index",
				"binding": "news_snapshotter_history_index"
			},
			{
				"queue": "news-snapshotter-history-index-dlq",
				"binding": "news_snapshotter_history_index_dlq"
			}
		],
		"consumers": [
			{
				"queue": "news-snapshotter-history-index"
			},
			{
				"queue": "news-snapshotter-history-index-dlq"
			}
		]
	}
}
