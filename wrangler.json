{
	"name": "news-snapshotter",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-16",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": false,
	"preview_urls": false,
	"placement": {
		"region": "aws:eu-west-1"
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 0.1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 0.1,
			"invocation_logs": false
		}
	},
	"dev": {
		"port": 8787
	},
	"vars": {
		"COMPARISON_CANARY_MODEL": "",
		"COMPARISON_CANARY_PERCENT": "0"
	},
	"triggers": {
		"crons": ["0 * * * *", "15 2 * * *", "30 2 * * 1", "45 2 1 * *", "15 3 2,7,14 * *"]
	},
	"routes": [
		{
			"pattern": "news-snapshotter.pashi.app",
			"custom_domain": true
		}
	],
	"browser": {
		"binding": "BROWSER"
	},
	"ai": {
		"binding": "AI"
	},
	"vectorize": [
		{
			"binding": "STORY_VECTORS",
			"index_name": "news-story-embeddings-v1",
			"remote": true
		}
	],
	"workflows": [
		{
			"name": "news-snapshotter",
			"binding": "NEWS_SNAPSHOTTER",
			"class_name": "NewsSnapshotterWorkflow"
		}
	],
	"kv_namespaces": [
		{
			"binding": "CAPTURE_FAILURES",
			"id": "eb6fb2073a344839a1ec735891a00527"
		}
	],
	"ratelimits": [
		{
			"name": "CONTACT_RATE_LIMIT",
			"namespace_id": "78241",
			"simple": {
				"limit": 3,
				"period": 60
			}
		},
		{
			"name": "COMPARISON_FEEDBACK_RATE_LIMIT",
			"namespace_id": "78242",
			"simple": {
				"limit": 5,
				"period": 60
			}
		}
	],
	"send_email": [
		{
			"name": "CONTACT_EMAIL"
		}
	],
	"r2_buckets": [
		{
			"binding": "ARCHIVE_DATA",
			"bucket_name": "news-snapshotter-archive-data",
			"preview_bucket_name": "news-snapshotter-archive-data-preview"
		},
		{
			"binding": "SCREENSHOTS",
			"bucket_name": "news-snapshotter",
			"preview_bucket_name": "news-snapshotter-preview"
		}
	],
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*"]
	},
	"d1_databases": [
		{
			"binding": "HISTORY_DB",
			"database_name": "news-snapshotter-history",
			"database_id": "903439ec-9e2f-432b-9c7a-fcd349d28620",
			"migrations_dir": "migrations",
			"remote": false
		}
	],
	"queues": {
		"producers": [
			{
				"queue": "news-snapshotter-history-index",
				"binding": "HISTORY_INDEX_QUEUE"
			},
			{
				"queue": "news-snapshotter-analysis",
				"binding": "ANALYSIS_QUEUE"
			}
		],
		"consumers": [
			{
				"queue": "news-snapshotter-history-index",
				"max_batch_size": 10,
				"max_batch_timeout": 5,
				"max_retries": 5,
				"dead_letter_queue": "news-snapshotter-history-index-dlq",
				"max_concurrency": 1
			},
			{
				"queue": "news-snapshotter-analysis",
				"max_batch_size": 1,
				"max_batch_timeout": 5,
				"max_retries": 5,
				"dead_letter_queue": "news-snapshotter-analysis-dlq",
				"max_concurrency": 1
			}
		]
	}
}
